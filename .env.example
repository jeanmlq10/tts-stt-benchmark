# ── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Deepgram ─────────────────────────────────────────────────────────────────
DEEPGRAM_API_KEY=...

# ── Google Cloud ─────────────────────────────────────────────────────────────
# Path to a service-account JSON key file with TTS permissions
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# Or inline base-64 encoded JSON (alternative to the file path above)
# GOOGLE_CREDENTIALS_JSON_B64=...

# ── Speechmatics ─────────────────────────────────────────────────────────────
SPEECHMATICS_API_KEY=...

# ── Benchmark defaults ───────────────────────────────────────────────────────
# Number of repetitions per test case (for p50/p90 stats)
BENCHMARK_REPETITIONS=5
# Output directory for results (relative to repo root)
BENCHMARK_OUTPUT_DIR=results
# Timeout per request in seconds
BENCHMARK_TIMEOUT_SECONDS=120
